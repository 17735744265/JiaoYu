# ============================================
# 环境变量配置模板
# 使用方法: 复制为 .env 并填入你的实际值
#   cp .env.example .env
# ============================================

# --- LLM API 配置 ---
# DeepSeek API（推荐，有免费额度）
# 注册地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=*****************************
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=sk-aad96350648847638e766f299f7856d2*****************************



# 如果用 OpenAI，取消下面注释
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 向量库配置 ---
CHROMA_PERSIST_DIR=./chroma_db   # Chroma数据持久化目录

# --- Embedding 模型 ---
# 使用本地BGE模型（首次运行会自动下载，约100MB）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8000

# --- 日志 ---
LOG_LEVEL=INFO
